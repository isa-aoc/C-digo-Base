programa
{
	
	funcao inicio()
	{// Calcular a idade que fará no ano atual
		inteiro ano_de_nascimento, ano_atual, idade
		escreva ("Ano de nascimento: ")
		leia (ano_de_nascimento)
		escreva ("Ano atual: ")
		leia (ano_atual)
		idade = ano_atual - ano_de_nascimento
		escreva ("Esse ano você fará: ", idade)	
					}
}
